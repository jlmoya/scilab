    <refsection xml:id="Description_DIFF_f">
        <title>Description</title>
        <para>This block computes the derivative of the input.</para>
    </refsection>
    <refsection xml:id="Dialogbox_DIFF_f">
        <title>Parameters</title>
        <mediaobject>
            <imageobject>
                <imagedata align="center" fileref="../../../../images/gui/DIFF_f_gui.gif"/>
            </imageobject>
        </mediaobject>
        <itemizedlist>
            <listitem>
                <para>
                    <emphasis role="bold">Initial state</emphasis>
                </para>
                <para>The initial continuous state.</para>
                <para>Properties : Type 'vec' of size 1.</para>
            </listitem>
            <listitem>
                <para>
                    <emphasis role="bold">Initial Derivative</emphasis>
                </para>
                <para>The initial derivative state.</para>
                <para>Properties : Type 'vec' of size 1.</para>
            </listitem>
        </itemizedlist>
    </refsection>
