<?xml version="1.0" encoding="UTF-8"?>
<refentry xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink" xml:id="tbxRemove" xml:lang="en">
    <refnamediv>
        <refname>tbxRemove</refname>
        <refpurpose>unregister and remove a toolbox</refpurpose>
    </refnamediv>
    <refsynopsisdiv>
        <title>Syntax</title>
        <synopsis>
tbxRemove(name)
        </synopsis>
    </refsynopsisdiv>
    <refsection>
        <title>Description</title>
        <para>Unloads the toolbox, removes it from the manifest, and deletes its clone only when it was installed from a <literal>"remote"</literal> source (a local <literal>SciLabProjects</literal> working clone is never deleted).</para>
    </refsection>
    <refsection>
        <title>Examples</title>
        <programlisting role="example"><![CDATA[
tbxRemove("cgal");
]]></programlisting>
    </refsection>
