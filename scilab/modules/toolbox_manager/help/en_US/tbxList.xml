<?xml version="1.0" encoding="UTF-8"?>
<refentry xmlns="http://docbook.org/ns/docbook" xmlns:xlink="http://www.w3.org/1999/xlink" xml:id="tbxList" xml:lang="en">
    <refnamediv>
        <refname>tbxList</refname>
        <refpurpose>list the installed toolboxes</refpurpose>
    </refnamediv>
    <refsynopsisdiv>
        <title>Syntax</title>
        <synopsis>
tbxList()
        </synopsis>
    </refsynopsisdiv>
    <refsection>
        <title>Description</title>
        <para>Prints the installed toolboxes with their source, autoload flag and path, read from the manifest <literal>SCIHOME/installed_toolboxes.tbx</literal>.</para>
    </refsection>
    <refsection>
        <title>Examples</title>
        <programlisting role="example"><![CDATA[
tbxList();
]]></programlisting>
    </refsection>
