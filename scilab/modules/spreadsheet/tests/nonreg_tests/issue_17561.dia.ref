          Max   3      2025-12-12   03:00:00
           Q1   1      2025-12-10   01:00:00
         Mean   2      2025-12-11   02:00:00
           Q3   3      2025-12-12   03:00:00
          Std   1      24:00:00     01:00:00
          Var   1                           
         Mode   1      2025-12-10   01:00:00
        Range   2                   02:00:00
          Sum   6                   06:00:00
    NumUnique   3      3            3       
          Nnz   3      3            3       
summary(t, "sum")
